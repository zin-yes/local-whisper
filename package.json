{
  "name": "local-whisper",
  "version": "1.0.0",
  "description": "Local voice transcription using Whisper — like MacWhisper for Windows",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "whisper",
    "transcription",
    "voice",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-store": "^8.2.0",
    "node-global-key-listener": "^0.3.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.2"
  },
  "build": {
    "appId": "com.localwhisper.app",
    "productName": "Local Whisper",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "resources/whisper",
        "to": "whisper"
      }
    ],
    "files": [
      "out/**/*"
    ]
  }
}
